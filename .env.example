# myDAUST environment template — committed. Copy to .env and fill real values.
# .env is gitignored. NEVER put real secrets in this file.

# --- AWS (pointers only — creds come from the SSO profile, NOT from here) ---
AWS_PROFILE=961828155948_DAUST_ADMIN
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=961828155948

# --- Cloudflare (DNS-as-code) ---
# Scoped token: DNS edit + Origin CA on the azertica.com zone. SECRET — local .env only.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE=azertica.com

# --- PayTech (Senegal payment gateway) — SANDBOX ---
# SECRET. Use ROTATED sandbox keys. Local .env only; staging/prod via AWS Secrets Manager.
PAYTECH_API_KEY=
PAYTECH_API_SECRET=
PAYTECH_ENV=sandbox
# Public URLs PayTech redirects/callbacks hit (local dev uses a cloudflared tunnel URL for IPN):
PAYTECH_IPN_URL=
PAYTECH_SUCCESS_URL=
PAYTECH_CANCEL_URL=

# --- Database ---
DATABASE_URL=postgresql://mydaust:mydaust@localhost:5432/mydaust?schema=public

# --- Observability (DSN/keys are publishable but env-managed; auth token is SECRET) ---
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
